# ─────────────────────────────────────────────────────────────────────────────
# Core runtime
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
# Comma-separated origins allowed for CORS / socket.io. Required in production.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Trading mode: 'paper' (simulated) or 'live'. Live also requires ENABLE_LIVE_TRADING=true.
TRADING_MODE=paper
ENABLE_LIVE_TRADING=false

# Graceful shutdown deadline (ms) before process.exit fallback.
SHUTDOWN_TIMEOUT_MS=10000

# ─────────────────────────────────────────────────────────────────────────────
# Binance
# ─────────────────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# ─────────────────────────────────────────────────────────────────────────────
# MongoDB (optional; persistence disabled if unset)
# ─────────────────────────────────────────────────────────────────────────────
MONGO_URI=
MONGO_DB_NAME=

# ─────────────────────────────────────────────────────────────────────────────
# Observability / debug
# ─────────────────────────────────────────────────────────────────────────────
# Set to "1" to log slow emit / book latency warnings above LATENCY_WARN_MS.
LATENCY_DEBUG=0
LATENCY_WARN_MS=8
# Warn when the pending-deltas buffer in LocalOrderBookEngine grows past this.
LATENCY_BUFFER_WARN_THRESHOLD=500

# ─────────────────────────────────────────────────────────────────────────────
# Local order book engine (Phase 1)
# ─────────────────────────────────────────────────────────────────────────────
# Top-K levels retained per side. Lower = less memory, more pruning churn.
MAX_BOOK_LEVELS=250
# Levels included in each book emit payload (must be <= MAX_BOOK_LEVELS).
EMIT_DEPTH=100
# Minimum interval (ms) between two book emits per symbol.
EMIT_THROTTLE_MS=50
# Cap on buffered diff-depth deltas awaiting snapshot reconciliation.
MAX_PENDING_DELTAS=2000

# ─────────────────────────────────────────────────────────────────────────────
# Depth-queue backpressure (FuturesAssetSocketAdapter)
# ─────────────────────────────────────────────────────────────────────────────
DEPTH_QUEUE_MAX=400
DEPTH_DRAIN_BATCH=50
DEPTH_DRAIN_TIME_BUDGET_MS=6
DEPTH_COALESCE_THRESHOLD=120
DEPTH_COALESCE_WINDOW=20
DEPTH_MAX_AGE_MS=300
DEPTH_DROP_CHUNK_PCT=0.25
# When the depth queue grows beyond this, skip heavy derived services for the frame.
DEPTH_BACKPRESSURE_SKIP_SERVICES_THRESHOLD=180
# Trades older than (latest seen - this) are dropped as out-of-order.
TRADE_OUT_OF_ORDER_TOLERANCE_MS=150

# ─────────────────────────────────────────────────────────────────────────────
# Socket.IO transport (Phase 2.B)
# ─────────────────────────────────────────────────────────────────────────────
# Enable perMessageDeflate compression (CPU cost on every emit; only enable if
# bandwidth-constrained).
SOCKETIO_DEFLATE=false
# Coalesce TRADE_AGG / MARK_PRICE / CVD emits into *_BATCH events. Requires a
# client that handles the batch variants — leave false until the frontend opts in.
EMIT_BATCH_MODE=false
EMIT_BATCH_WINDOW_MS=50

# ─────────────────────────────────────────────────────────────────────────────
# Binance stream gating (Phase 2.A)
# ─────────────────────────────────────────────────────────────────────────────
# Re-enable the redundant futuresPartialDepth stream. Default off because
# book:local (reconstructed from diff-depth) carries the same information.
EMIT_BOOK_PARTIAL=false

# ─────────────────────────────────────────────────────────────────────────────
# Mongo write batching (Phase 4)
# ─────────────────────────────────────────────────────────────────────────────
MONGO_SIGNAL_BUFFER_MAX=50
MONGO_SIGNAL_FLUSH_MS=500
MONGO_POSITION_BUFFER_MAX=25
MONGO_POSITION_FLUSH_MS=250

# ─────────────────────────────────────────────────────────────────────────────
# Worker thread pool (Phase 3 — skeleton, not yet wired into the container)
# ─────────────────────────────────────────────────────────────────────────────
# Override the auto-sized pool (default: cpus - 1). Only takes effect once
# REALTIME_MODE=workerPool is activated in the composition root.
# WORKER_POOL_SIZE=

# ─────────────────────────────────────────────────────────────────────────────
# Signal engine horizon (scalp profile)
# ─────────────────────────────────────────────────────────────────────────────
# 'default' keeps the legacy weights. 'scalp' enables the micro-operation profile
# (order-flow heavy weights, counter-trend EMA gate, cost-aware risk gate, time-stop).
SIGNAL_HORIZON=default

# ─────────────────────────────────────────────────────────────────────────────
# Execution mode
# ─────────────────────────────────────────────────────────────────────────────
# 'auto' (default) → the bot self-executes every signal that clears the hard
#                    risk gates (spread, cost-edge, daily-loss brake, open
#                    position). Soft-fail signals (low confidence / R/R /
#                    same-side spoof) are also executed automatically as long
#                    as the dynamic risk policy produced a valid adjusted-risk
#                    plan. NO manual popup.
# 'semi'           → soft-fail signals surface a popup so a human can approve
#                    or reject them. Hard gates still block silently.
EXECUTION_MODE=auto
# When EXECUTION_MODE=semi, how long (ms) the entry signal stays valid for
# human approval. Floors the engine's ATR-scaled 10–30s default so the popup
# doesn't expire while the trader is still looking at it.
MANUAL_REVIEW_EXPIRY_MS=60000

# ─────────────────────────────────────────────────────────────────────────────
# Paper account / dynamic position sizing (consumed when SIGNAL_HORIZON=scalp)
# ─────────────────────────────────────────────────────────────────────────────
# Simulated account equity (USDT) used to size paper trades.
PAPER_ACCOUNT_EQUITY=10000
# Fraction of equity risked per trade (0.005 = 0.5%).
RISK_PER_TRADE_PCT=0.005
# Hard cap on notional per order. Leave empty for no cap.
RISK_MAX_NOTIONAL_PER_ORDER=
# Contract size multiplier (1 for USDT-margined linear futures).
CONTRACT_MULTIPLIER=1

# ─────────────────────────────────────────────────────────────────────────────
# Trading costs / edge filter
# ─────────────────────────────────────────────────────────────────────────────
# Taker fee per side in basis points (Binance USDT-M default ≈ 4 bps).
TRADING_FEE_BPS=4
# Estimated slippage per side in basis points.
TRADING_SLIPPAGE_BPS=2
# Reject signals whose expected TP < edgeMultiple × round-trip cost.
TRADING_EDGE_MULTIPLE=3

# ─────────────────────────────────────────────────────────────────────────────
# Active-position management (scalp time-stop)
# ─────────────────────────────────────────────────────────────────────────────
# Close a position after this many ms if it has not progressed enough toward TP.
# 0 disables the time-stop (default). 60000 recommended for scalp.
POSITION_TIME_STOP_MS=0
# Minimum fraction of TP reached to avoid the time-stop (0.30 = 30%).
POSITION_MIN_TP_PROGRESS=0.30

# ─────────────────────────────────────────────────────────────────────────────
# Risk Manager — pre-trade hard limits (RiskRulesConfig)
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated whitelist of tradable symbols. Empty = allow all.
RISK_ALLOWED_SYMBOLS=
# Reject orders whose quantity exceeds this value. Empty = no limit.
RISK_MAX_ORDER_QTY=
# Reject when the resulting notional per symbol exceeds this (USDT). Empty = no limit.
RISK_MAX_NOTIONAL_PER_SYMBOL=
# Maximum simultaneous open positions across all symbols. Empty = no limit.
RISK_MAX_OPEN_POSITIONS=
# Block new orders once the realized PnL of the day falls below -RISK_MAX_DAILY_LOSS.
# Empty = no daily loss brake.
RISK_MAX_DAILY_LOSS=
